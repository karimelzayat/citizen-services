{
  "entities": {
    "Complaint": {
      "title": "Complaint",
      "description": "Represents a citizen complaint record",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "callerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "governorate": { "type": "string" },
        "isEmergency": { "type": "boolean" },
        "hospitalType": { "type": "string" },
        "responsibleEntity": { "type": "string" },
        "hospitalName": { "type": "string" },
        "hospitalAddress": { "type": "string" },
        "diagnosis": { "type": "string" },
        "subject": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string" },
        "followUpStatus": { "type": "string" },
        "followUpNotes": { "type": "string" },
        "employeeName": { "type": "string" },
        "employeeEmail": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "isCabinetComplaint": { "type": "boolean" },
        "cabinetId": { "type": "string" },
        "cabinetNumber": { "type": "string" },
        "nationalId": { "type": "string" },
        "city": { "type": "string" }
      }
    },
    "AdminComplaint": {
      "title": "Admin Complaint",
      "description": "Records for administration work",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "workType": { "type": "string" },
        "complaintNo": { "type": "string" },
        "governorate": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "registrant": { "type": "string" },
        "employeeName": { "type": "string" },
        "employeeEmail": { "type": "string" }
      }
    },
    "DirectorCase": {
      "title": "Director Case",
      "description": "Assignments from the Director's office",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "caseName": { "type": "string" },
        "phone": { "type": "string" },
        "details": { "type": "string" },
        "employee": { "type": "string" },
        "action": { "type": "string" },
        "status": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "attachmentUrl": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System and user notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "actionLink": { "type": "string" }
      }
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Monthly shift schedules mapping staff to specific shifts and roles",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "day": { "type": "string" },
        "monthYear": { "type": "string" },
        "shift24": { "type": "string" },
        "shift36": { "type": "string" },
        "holidayMorning": { "type": "string" },
        "holidayNoon": { "type": "string" },
        "cabinet1": { "type": "string" },
        "cabinet2": { "type": "string" },
        "cabinet3": { "type": "string" },
        "careMorning": { "type": "string" },
        "careNight": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Instant inquiries between employees",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "question": { "type": "string" },
        "qUser": { "type": "string" },
        "answer": { "type": "string" },
        "aUser": { "type": "string" }
      }
    },
    "FAQ": {
      "title": "FAQ",
      "description": "FAQ entries",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "UserPermission": {
      "title": "User Permission",
      "description": "User roles and capabilities",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "PhonebookEntry": {
      "title": "Phonebook Entry",
      "description": "Contact information for a specific entity and governorate",
      "type": "object",
      "properties": {
        "entity": { "type": "string" },
        "governorate": { "type": "string" },
        "phone": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "HotlineTreeEntry": {
      "title": "Hotline Tree Entry",
      "description": "A node in the hotline guidance tree",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "phone": { "type": "string" },
        "info": { "type": "string" },
        "parentId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "complaints": { "schema": "Complaint", "description": "Hotline complaints" },
    "admin_complaints": { "schema": "AdminComplaint", "description": "Administration work items" },
    "director_cases": { "schema": "DirectorCase", "description": "Director assignments" },
    "notifications": { "schema": "Notification", "description": "User notifications" },
    "schedules": { "schema": "Schedule", "description": "Monthly shift schedules" },
    "inquiries": { "schema": "Inquiry", "description": "Instant inquiries" },
    "faq": { "schema": "FAQ", "description": "FAQ database" },
    "user_permissions": { "schema": "UserPermission", "description": "User role management" },
    "phonebook": { "schema": "PhonebookEntry", "description": "Staff and entity phone directory" },
    "hotline_tree": { "schema": "HotlineTreeEntry", "description": "Hotline routing tree" }
  }
}
