rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'karimelzayat3@gmail.com' || 
        request.auth.token.email == 'karimelzayat.1997@gmail.com'
      );
    }

    // Default deny for safety
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Employees & Permissions
    match /employees/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /user_permissions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /role_capabilities/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Complaints
    match /complaints/{complaintId} {
      allow read: if isSignedIn();
      allow create: if true; 
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Admin Complaints
    match /admin_complaints/{id} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Director Cases
    match /director_cases/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Inquiries
    match /inquiries/{id} {
      allow read, create: if true;
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Schedules, FAQ, Phonebook, Hotline (Publicly readable)
    match /schedules/{id} { allow read: if true; allow write: if isAdmin(); }
    match /faq/{id} { allow read: if true; allow write: if isAdmin(); }
    match /phonebook/{id} { allow read: if true; allow write: if isAdmin(); }
    match /hotline_tree/{id} { allow read: if true; allow write: if isAdmin(); }
    
    match /notifications/{id} { 
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Follow-up Collections
    match /followUpPending/{id} {
      allow read, create, update, delete: if isSignedIn();
    }
    match /followUpCompleted/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
